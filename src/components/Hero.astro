---
---
<section id="hero">
  <div id="scroll-container">
    <div id="sticky-wrapper">
      <canvas id="frame-canvas"></canvas>
      <div id="canvas-overlay"></div>

      <div class="particles" aria-hidden="true">
        {Array.from({ length: 16 }).map((_, i) => (
          <svg class="leaf-particle" style={`--i:${i}`} viewBox="0 0 40 60" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M20 55 C20 55 2 35 2 20 C2 10 10 2 20 2 C30 2 38 10 38 20 C38 35 20 55 20 55Z" fill="currentColor"/>
            <line x1="20" y1="8" x2="20" y2="52" stroke="rgba(255,255,255,0.3)" stroke-width="1"/>
          </svg>
        ))}
      </div>

      <!-- Texto del hero — se desvanece al hacer scroll (desktop) -->
      <div class="hero-content">
        <p class="hero-eyebrow">El mundo vegetal</p>
        <h1 class="hero-title">
          <span class="line line-1">La vida</span>
          <span class="line line-2">que crece</span>
          <span class="line line-3 accent">en silencio</span>
        </h1>
        <p class="hero-subtitle">
          <span id="typewriter"></span><span class="cursor">|</span>
        </p>
      </div>

      <!-- Botón independiente — no se mueve con el texto en desktop -->
      <button class="cta-btn" id="cta-btn" aria-label="Explorar contenido">
        <span class="btn-text">Explorar</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M12 5v14M5 12l7 7 7-7"/>
        </svg>
        <span class="ripple-container"></span>
      </button>

      <div class="scroll-hint">
        <div class="scroll-line"></div>
        <span>Scroll para ver crecer</span>
      </div>
    </div>
  </div>
</section>

<div class="wave-sep" aria-hidden="true">
  <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80Z" fill="#1a4a2e"/></svg>
</div>

<style>
  #hero { background: var(--c-deep); }
  #scroll-container { height: 500vh; background: var(--c-deep); }

  #sticky-wrapper {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #frame-canvas { position: absolute; inset: 0; width: 100%; height: 100%; }

  #canvas-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(13,43,26,.6) 0%, rgba(13,43,26,.2) 45%, rgba(13,43,26,.75) 100%);
  }

  .particles { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
  .leaf-particle {
    position: absolute;
    color: var(--c-light);
    width: calc(12px + var(--i) * 4px);
    opacity: calc(0.04 + var(--i) * 0.014);
    left: calc(var(--i) * 6.25%);
    top: calc(10% + (var(--i) * 5%));
    animation:
      leaf-drift calc(8s + var(--i) * 0.6s) ease-in-out infinite alternate,
      leaf-spin  calc(12s + var(--i) * 1s)  linear infinite;
    animation-delay: calc(var(--i) * -0.5s);
  }
  @keyframes leaf-drift {
    from { transform: translateY(0) translateX(0); }
    to   { transform: translateY(-60px) translateX(20px); }
  }
  @keyframes leaf-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* ── Hero text ── */
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: var(--c-text);
    padding: 0 1.5rem;
    max-width: 820px;
    will-change: transform, opacity;
  }

  .hero-eyebrow {
    font-size: .72rem;
    font-weight: 500;
    letter-spacing: .4em;
    text-transform: uppercase;
    color: var(--c-light);
    margin-bottom: 1.8rem;
    animation: fade-up .8s var(--ease-out) both;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(3.2rem, 9vw, 7.5rem);
    font-weight: 800;
    line-height: 1;
    margin-bottom: 1.6rem;
  }
  .line { display: block; }
  .line-1 { animation: fade-up .9s .15s var(--ease-out) both; }
  .line-2 { animation: fade-up .9s .30s var(--ease-out) both; }
  .line-3 { animation: fade-up .9s .45s var(--ease-out) both; }
  .accent  { color: var(--c-light); font-style: italic; }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--c-muted);
    max-width: 520px;
    margin: 0 auto 0;
    line-height: 1.75;
    min-height: 2.5em;
    animation: fade-up .8s .6s var(--ease-out) both;
  }

  .cursor { animation: blink 1s step-end infinite; color: var(--c-light); }
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  /* ── CTA button ── */
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: .65rem;
    padding: .9rem 2.2rem;
    min-height: 44px;
    border: 1.5px solid var(--c-light);
    border-radius: 100px;
    background: transparent;
    color: var(--c-light);
    font-family: var(--font-sans);
    font-size: .95rem;
    cursor: pointer;
    overflow: hidden;
    transition: background var(--transition-base), color var(--transition-base), transform .15s;
    animation: fade-up .8s .75s var(--ease-out) both;
  }
  .cta-btn svg { width: 18px; height: 18px; transition: transform var(--transition-base); flex-shrink: 0; }
  .cta-btn:hover { background: var(--c-light); color: var(--c-deep); }
  .cta-btn:hover svg { transform: translateY(3px); }
  .cta-btn:active { transform: scale(.97); }
  .ripple-container { position: absolute; inset: 0; pointer-events: none; }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Scroll hint ── */
  .scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .5rem;
    color: var(--c-muted);
    font-size: .68rem;
    letter-spacing: .18em;
    text-transform: uppercase;
    animation: fade-up 1s 1.3s var(--ease-out) both;
    pointer-events: none;
  }
  .scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, transparent, var(--c-light));
    animation: scroll-pulse 1.8s ease-in-out infinite;
  }
  @keyframes scroll-pulse {
    0%, 100% { opacity: .3; transform: scaleY(.5); transform-origin: top; }
    50%       { opacity: 1;  transform: scaleY(1); }
  }

  /* ── Desktop: botón fijo abajo-derecha, independiente del texto ── */
  @media (min-width: 768px) {
    .cta-btn {
      position: absolute;
      bottom: 2.2rem;
      right: 2.5rem;
      z-index: 3;
    }
  }

  /* ── Mobile: planta sin fondo + texto abajo ── */
  @media (max-width: 767px) {
    #hero,
    #scroll-container { background: #000; height: 400vh; }

    #canvas-overlay { display: none; }

    #sticky-wrapper {
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-end;
      padding: 0 0 6vh;
    }

    .hero-content {
      text-align: left;
      max-width: 100%;
      padding: 0 1.4rem;
    }

    /* Gradiente local para que el texto sea legible sobre la planta */
    .hero-content::before {
      content: '';
      position: absolute;
      inset: -3rem -1.4rem -0.5rem;
      background: linear-gradient(to top, rgba(0,0,0,.88) 55%, transparent 100%);
      z-index: -1;
      pointer-events: none;
    }

    .hero-eyebrow { margin-bottom: .9rem; }

    .hero-title {
      font-size: clamp(2.4rem, 11vw, 3.4rem);
      margin-bottom: 1rem;
    }

    .hero-subtitle {
      font-size: .95rem;
      max-width: 100%;
      margin: 0 0 1.4rem;
      min-height: unset;
    }

    /* Botón en flujo normal debajo del texto en móvil */
    .cta-btn {
      position: relative;
      margin-left: 1.4rem;
      font-size: .88rem;
      padding: .75rem 1.6rem;
      animation: none;
      opacity: 1;
    }

    .particles   { display: none; }
    .scroll-hint { display: none; }
  }
</style>

<script>
  import '../scripts/frameCanvas';
  import '../scripts/typewriter';
  import '../scripts/ripple';

  const btn         = document.getElementById('cta-btn')!;
  const container   = document.getElementById('scroll-container')!;
  const heroContent = document.querySelector<HTMLElement>('.hero-content')!;

  /* ── Texto sube al hacer scroll (solo desktop) ── */
  function updateHeroText() {
    if (window.innerWidth < 768) return;
    const scrolled = window.scrollY - container.offsetTop;
    const total    = container.offsetHeight - window.innerHeight;
    const progress = Math.min(Math.max(scrolled / total, 0), 1);
    const t = Math.min(progress / 0.30, 1);
    heroContent.style.opacity   = String(1 - t);
    heroContent.style.transform = `translateY(${-110 * t}px)`;
  }
  window.addEventListener('scroll', updateHeroText, { passive: true });

  /* ── Botón: reproduce planta + sube el texto en sincronía (~3.5 s) ── */
  btn.addEventListener('click', () => {
    const play = (window as any).__playPlantAnimation;
    if (!play) return;

    play(3500, (p: number) => {
      // Solo animar texto en desktop (en móvil el texto queda abajo)
      if (window.innerWidth < 768) return;
      // El texto desaparece en el primer 35% de la animación
      const t = Math.min(p / 0.35, 1);
      heroContent.style.opacity   = String(1 - t);
      heroContent.style.transform = `translateY(${-110 * t}px)`;
    });
  });
</script>
