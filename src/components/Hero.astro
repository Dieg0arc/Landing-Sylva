---
---
<section id="hero">
  <div id="scroll-container">
    <div id="sticky-wrapper">
      <canvas id="frame-canvas"></canvas>
      <div id="canvas-overlay"></div>

      <div class="particles" aria-hidden="true">
        {Array.from({ length: 16 }).map((_, i) => (
          <svg class="leaf-particle" style={`--i:${i}`} viewBox="0 0 40 60" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M20 55 C20 55 2 35 2 20 C2 10 10 2 20 2 C30 2 38 10 38 20 C38 35 20 55 20 55Z" fill="currentColor"/>
            <line x1="20" y1="8" x2="20" y2="52" stroke="rgba(255,255,255,0.3)" stroke-width="1"/>
          </svg>
        ))}
      </div>

      <div class="hero-content">
        <p class="hero-eyebrow">El mundo vegetal</p>
        <h1 class="hero-title">
          <span class="line line-1">La vida</span>
          <span class="line line-2">que crece</span>
          <span class="line line-3 accent">en silencio</span>
        </h1>
        <p class="hero-subtitle">
          <span id="typewriter"></span><span class="cursor">|</span>
        </p>
        <button class="cta-btn" id="cta-btn" onclick="document.getElementById('growth').scrollIntoView({behavior:'smooth'})">
          <span class="btn-text">Explorar</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 5v14M5 12l7 7 7-7"/>
          </svg>
          <span class="ripple-container"></span>
        </button>
      </div>

      <div class="scroll-hint">
        <div class="scroll-line"></div>
        <span>Scroll para ver crecer</span>
      </div>
    </div>
  </div>
</section>

<div class="wave-sep" aria-hidden="true">
  <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80Z" fill="#1a4a2e"/></svg>
</div>

<style>
  #hero { background: var(--c-deep); }

  #scroll-container { height: 2000vh; background: var(--c-deep); }

  #sticky-wrapper {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #frame-canvas { position: absolute; inset: 0; width: 100%; height: 100%; }

  #canvas-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(13,43,26,.6) 0%, rgba(13,43,26,.2) 45%, rgba(13,43,26,.75) 100%);
  }

  .particles { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }

  .leaf-particle {
    position: absolute;
    color: var(--c-light);
    width: calc(12px + var(--i) * 4px);
    opacity: calc(0.04 + var(--i) * 0.014);
    left: calc(var(--i) * 6.25%);
    top: calc(10% + (var(--i) * 5%));
    animation:
      leaf-drift calc(8s + var(--i) * 0.6s) ease-in-out infinite alternate,
      leaf-spin  calc(12s + var(--i) * 1s)  linear infinite;
    animation-delay: calc(var(--i) * -0.5s);
  }
  @keyframes leaf-drift {
    from { transform: translateY(0) translateX(0); }
    to   { transform: translateY(-60px) translateX(20px); }
  }
  @keyframes leaf-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: var(--c-text);
    padding: 0 1.5rem;
    max-width: 820px;
  }

  .hero-eyebrow {
    font-size: .72rem;
    font-weight: 500;
    letter-spacing: .4em;
    text-transform: uppercase;
    color: var(--c-light);
    margin-bottom: 1.8rem;
    animation: fade-up .8s var(--ease-out) both;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(3.2rem, 9vw, 7.5rem);
    font-weight: 800;
    line-height: 1;
    margin-bottom: 1.6rem;
  }

  .line { display: block; }
  .line-1 { animation: fade-up .9s .15s var(--ease-out) both; }
  .line-2 { animation: fade-up .9s .30s var(--ease-out) both; }
  .line-3 { animation: fade-up .9s .45s var(--ease-out) both; }
  .accent  { color: var(--c-light); font-style: italic; }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--c-muted);
    max-width: 520px;
    margin: 0 auto 2.8rem;
    line-height: 1.75;
    min-height: 2.5em;
    animation: fade-up .8s .6s var(--ease-out) both;
  }

  .cursor { animation: blink 1s step-end infinite; color: var(--c-light); }
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  .cta-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: .65rem;
    padding: .9rem 2.2rem;
    border: 1.5px solid var(--c-light);
    border-radius: 100px;
    background: transparent;
    color: var(--c-light);
    font-family: var(--font-sans);
    font-size: .95rem;
    cursor: pointer;
    overflow: hidden;
    transition: background var(--transition-base), color var(--transition-base), transform .15s;
    animation: fade-up .8s .75s var(--ease-out) both;
  }
  .cta-btn svg { width: 18px; height: 18px; transition: transform var(--transition-base); flex-shrink: 0; }
  .cta-btn:hover { background: var(--c-light); color: var(--c-deep); }
  .cta-btn:hover svg { transform: translateY(3px); }
  .cta-btn:active { transform: scale(.97); }
  .ripple-container { position: absolute; inset: 0; pointer-events: none; }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .5rem;
    color: var(--c-muted);
    font-size: .68rem;
    letter-spacing: .18em;
    text-transform: uppercase;
    animation: fade-up 1s 1.3s var(--ease-out) both;
  }
  .scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, transparent, var(--c-light));
    animation: scroll-pulse 1.8s ease-in-out infinite;
  }
  @keyframes scroll-pulse {
    0%, 100% { opacity: .3; transform: scaleY(.5); transform-origin: top; }
    50%       { opacity: 1;  transform: scaleY(1); }
  }
</style>

<script>
  import '../scripts/frameCanvas';
  import '../scripts/typewriter';
  import '../scripts/ripple';
</script>
