---
import { tips } from '../data/content';

const tipIcons = [
  // 💧 Water drop (Lucide Droplets)
  `<svg class="tip-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.54 3 5.48a6.98 6.98 0 0 1-11.91 4.97"/></svg>`,
  // ☀️ Sun
  `<svg class="tip-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>`,
  // 🪱 Sprout (soil/nature)
  `<svg class="tip-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 20h10"/><path d="M10 20c5.5-2.5.8-6.4 3-9"/><path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"/><path d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z"/></svg>`,
  // 🌡️ Thermometer
  `<svg class="tip-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/></svg>`,
];
---
<section id="tips" class="section-tips">
  <div class="section-inner">
    <p class="section-label">Cultivo</p>
    <h2 class="section-title">Claves para que crezcan</h2>
    <div class="tips-list">
      {tips.map((t, i) => (
        <div class="tip-row reveal">
          <div class="tip-icon">
            <Fragment set:html={tipIcons[i]} />
            <p class="tip-pct">{t.w}</p>
          </div>
          <div class="tip-body">
            <h3>{t.title}</h3>
            <p>{t.text}</p>
            <div class="tip-bar"><div class="tip-fill" style={`--w:${t.w}`}></div></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-tips { background: var(--c-dark); color: var(--c-text); }

  .tips-list { display: flex; flex-direction: column; gap: 1.2rem; margin-top: 3rem; }

  .tip-row {
    display: grid;
    grid-template-columns: 64px 1fr;
    align-items: start;
    gap: 1.5rem;
    background: rgba(255,255,255,.035);
    border: var(--border-subtle);
    border-left: var(--border-accent);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    padding: 1.6rem 1.8rem;
    transition: background var(--transition-base), border-color var(--transition-base), border-left-width var(--transition-base);
  }
  .tip-row:hover {
    background: rgba(255,255,255,.055);
    border-left-width: 3px;
    border-color: rgba(126,200,160,.28);
  }
  @media (max-width: 640px) {
    .tip-row { grid-template-columns: 56px 1fr; gap: 1rem; }
  }

  .tip-icon {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .35rem;
    padding-top: .1rem;
    color: var(--c-light);
  }
  .tip-svg-icon {
    width: 24px;
    height: 24px;
    display: block;
  }
  .tip-pct {
    font-size: var(--text-xs);
    color: var(--c-muted);
    text-align: center;
    opacity: .7;
  }

  .tip-body h3 {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: .35rem;
    color: var(--c-pale);
  }
  .tip-body p { font-size: var(--text-sm); color: var(--c-muted); line-height: var(--lh-base); }

  .tip-bar {
    height: 3px;
    background: rgba(255,255,255,.07);
    border-radius: var(--radius-pill);
    overflow: hidden;
    margin-top: .6rem;
  }
  .tip-fill {
    height: 100%;
    width: 0;
    background: linear-gradient(to right, var(--c-mid), var(--c-light));
    border-radius: var(--radius-pill);
  }
</style>

<script>
  import { inView, animate } from 'motion';

  inView('.tip-row', (element) => {
    const fill = element.querySelector<HTMLElement>('.tip-fill');
    if (!fill) return;
    const target = fill.style.getPropertyValue('--w') || '0%';
    animate(fill, { width: ['0%', target] }, {
      duration: 1,
      delay: 0.15,
      easing: [0.16, 1, 0.3, 1],
    });
  }, { margin: '-5% 0px' });
</script>
