---
import { stages } from '../data/content';

const stageIcons = [
  // Germinación — sprout (Lucide Sprout)
  `<svg class="stage-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 20h10"/><path d="M10 20c5.5-2.5.8-6.4 3-9"/><path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"/><path d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z"/></svg>`,
  // Brote — leaf (Lucide Leaf)
  `<svg class="stage-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>`,
  // Crecimiento — trees (Lucide Trees)
  `<svg class="stage-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 10v.2A3 3 0 0 1 8.9 16v0H5v0h0a3 3 0 0 1-1-5.8V10a3 3 0 0 1 6 0Z"/><path d="M7 16v6"/><path d="M13 19v3"/><path d="M12 19h8.3a1 1 0 0 0 .7-1.7L18 14h.3a1 1 0 0 0 .7-1.7L16 9h.2a1 1 0 0 0 .8-1.7L13 3l-1.4 1.5"/></svg>`,
  // Floración — flower petals
  `<svg class="stage-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="9" r="2"/><ellipse cx="12" cy="4.5" rx="2" ry="2.5"/><ellipse cx="12" cy="13.5" rx="2" ry="2.5"/><ellipse cx="7.5" cy="9" rx="2.5" ry="2"/><ellipse cx="16.5" cy="9" rx="2.5" ry="2"/><path d="M12 11v11"/></svg>`,
];
---
<section id="growth" class="section-growth">
  <div class="section-inner">
    <p class="section-label">Ciclo de vida</p>
    <h2 class="section-title">Las etapas del crecimiento</h2>
    <p class="section-subtitle">
      Cada planta pasa por un viaje extraordinario desde su origen
      hasta su plenitud.
    </p>
    <div class="stages-grid">
      {stages.map((s, i) => (
        <div class="stage-card reveal" style={`--delay:${i * 0.1}s`}>
          <div class="stage-number" aria-hidden="true">{s.num}</div>
          <div class="stage-icon">
            <Fragment set:html={stageIcons[i]} />
          </div>
          <h3>{s.title}</h3>
          <p>{s.text}</p>
          <div class="card-glow" aria-hidden="true"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<div class="wave-sep" aria-hidden="true">
  <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,0 C480,80 960,0 1440,60 L1440,80 L0,80Z" fill="#0d2b1a"/></svg>
</div>

<style>
  .section-growth { background: var(--c-dark); color: var(--c-text); }

  .stages-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1.5rem;
  }

  .stage-card {
    position: relative;
    background: rgba(255,255,255,.04);
    border: var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--card-pad-md);
    overflow: hidden;
    cursor: default;
    opacity: 0;
    transition: border-color var(--transition-base), box-shadow var(--transition-base), transform var(--transition-base);
  }
  .stage-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(to right, var(--c-mid), var(--c-light));
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    opacity: 0;
    transition: opacity var(--transition-base);
  }
  .stage-card:hover {
    transform: translateY(-6px);
    border-color: rgba(126,200,160,.45);
    box-shadow: 0 24px 48px rgba(0,0,0,.35), 0 0 0 1px rgba(126,200,160,.1);
  }
  .stage-card:hover::before { opacity: 1; }

  .card-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(126,200,160,.12), transparent 70%);
    opacity: 0;
    transition: opacity var(--transition-base);
    pointer-events: none;
  }
  .stage-card:hover .card-glow { opacity: 1; }

  .stage-number {
    width: 28px; height: 28px;
    border-radius: 50%;
    border: var(--border-medium);
    color: var(--c-light);
    font-size: .75rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    flex-shrink: 0;
  }

  .stage-icon {
    margin-bottom: .9rem;
    display: block;
    color: var(--c-light);
  }
  .stage-svg-icon {
    width: 28px;
    height: 28px;
    display: block;
  }

  .stage-card h3 {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -.01em;
    margin-bottom: .6rem;
    color: var(--c-pale);
  }
  .stage-card p { font-size: var(--text-sm); color: var(--c-muted); line-height: var(--lh-loose); }
</style>

<script>
  import { inView, animate } from 'motion';

  document.querySelectorAll<HTMLElement>('.stage-card').forEach((card, i) => {
    inView(card, () => {
      animate(
        card,
        { opacity: [0, 1], transform: ['translateY(20px)', 'translateY(0)'] },
        { duration: 0.5, delay: i * 0.1, easing: [0.16, 1, 0.3, 1] }
      );
    }, { margin: '-10% 0px' });
  });
</script>
