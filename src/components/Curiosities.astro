---
import { curiosities } from '../data/content';

const curiosityIcons = [
  // 📡 Radio waves / signal
  `<svg class="curiosity-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"/><path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.5"/><circle cx="12" cy="12" r="2"/><path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.5"/><path d="M19.1 4.9C23 8.8 23 15.1 19.1 19"/></svg>`,
  // ⏳ Hourglass / timer
  `<svg class="curiosity-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 22h14"/><path d="M5 2h14"/><path d="M17 22v-4.172a2 2 0 0 0-.586-1.414L12 12l-4.414 4.414A2 2 0 0 0 7 17.828V22"/><path d="M7 2v4.172a2 2 0 0 0 .586 1.414L12 12l4.414-4.414A2 2 0 0 0 17 6.172V2"/></svg>`,
  // 🌙 Moon
  `<svg class="curiosity-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>`,
  // 🕸️ Network (Wood Wide Web)
  `<svg class="curiosity-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="5" r="2"/><circle cx="5" cy="19" r="2"/><circle cx="19" cy="19" r="2"/><path d="M12 7v3"/><path d="M5.27 17.27 10 14"/><path d="M13.73 14l4.97 3.27"/><path d="M10 14h4"/></svg>`,
  // 🌍 Globe
  `<svg class="curiosity-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>`,
  // 🎵 Music note
  `<svg class="curiosity-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`,
];
---

<!-- wave from Stats (#2d7a4f) into this section (#0d2b1a) -->
<div class="wave-sep wave-flip" aria-hidden="true">
  <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,50 C480,0 960,80 1440,20 L1440,0 L0,0Z" fill="#2d7a4f"/></svg>
</div>

<section id="curiosidades" class="section-curiosities">
  <div class="section-inner">
    <p class="section-label">¿Sabías que…?</p>
    <h2 class="section-title">El mundo vegetal te sorprenderá</h2>
    <div class="curiosities-grid">
      {curiosities.map((c, i) => (
        <blockquote class="curiosity-card reveal" style={`--delay:${i * 0.08}s`}>
          <div class="curiosity-icon">
            <Fragment set:html={curiosityIcons[i]} />
          </div>
          <span class="open-quote" aria-hidden="true">"</span>
          <p>{c.quote}</p>
          <footer>— {c.source}</footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>

<!-- wave into Tips (#1a4a2e) -->
<div class="wave-sep" aria-hidden="true">
  <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,50 C360,0 1080,80 1440,30 L1440,80 L0,80Z" fill="#1a4a2e"/></svg>
</div>

<style>
  .section-curiosities { background: var(--c-deep); color: var(--c-text); }
  .section-curiosities .section-inner { padding-top: 5rem; padding-bottom: 5rem; }

  .curiosities-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.2rem;
  }

  .curiosity-card {
    position: relative;
    background: rgba(255,255,255,.04);
    border: var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: 2rem 1.8rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: .6rem;
    transition: transform var(--transition-base), border-color var(--transition-base), box-shadow var(--transition-base);
  }
  .curiosity-card:hover {
    transform: translateY(-4px);
    border-color: rgba(126,200,160,.3);
    box-shadow: 0 16px 32px rgba(0,0,0,.25);
  }

  /* Alternating visual rhythm */
  .curiosity-card:nth-child(3n+1) { padding-bottom: 2.4rem; }
  .curiosity-card:nth-child(3n+2) { padding-top: 2.4rem; }

  .curiosity-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    background: rgba(126, 200, 160, 0.08);
    border: var(--border-subtle);
    color: var(--c-light);
    margin-bottom: .2rem;
    flex-shrink: 0;
  }
  .curiosity-svg-icon {
    width: 20px;
    height: 20px;
    display: block;
  }

  .open-quote {
    font-family: var(--font-serif);
    font-size: 4rem;
    line-height: .6;
    color: var(--c-mid);
    user-select: none;
    display: block;
  }

  .curiosity-card p {
    font-size: var(--text-base);
    color: var(--c-text);
    line-height: var(--lh-base);
    flex: 1;
  }

  .curiosity-card footer {
    font-size: var(--text-xs);
    color: var(--c-muted);
    letter-spacing: .05em;
    margin-top: .4rem;
    padding-top: .8rem;
    border-top: 1px solid rgba(126,200,160,.1);
  }
</style>

<script>
  import { inView, animate } from 'motion';

  document.querySelectorAll<HTMLElement>('.curiosity-card').forEach((card, i) => {
    inView(card, () => {
      animate(
        card,
        { opacity: [0, 1], transform: ['translateY(16px)', 'translateY(0)'] },
        { duration: 0.5, delay: i * 0.08, easing: [0.16, 1, 0.3, 1] }
      );
    }, { margin: '-8% 0px' });
  });
</script>
