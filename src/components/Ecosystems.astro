---
import { ecosystems } from '../data/content';

const ecoIcons = [
  // Selva Tropical — palm tree
  `<svg class="eco-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 22V11"/><path d="M13 11C11 7 6 6 3 8c1 5 5 7 10 3z"/><path d="M13 11c2-4 7-5 10-3-1 5-5 7-10 3z"/><path d="M13 15c-2-3-6-4-9-3 1 4 5 6 9 3z"/><path d="M10 22h6"/></svg>`,
  // Sabana — wheat
  `<svg class="eco-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 22 16 8"/><path d="M3.47 12.53 5 11l1.53 1.53a3.5 3.5 0 0 1 0 4.94L5 19l-1.53-1.53a3.5 3.5 0 0 1 0-4.94Z"/><path d="M7.47 8.53 9 7l1.53 1.53a3.5 3.5 0 0 1 0 4.94L9 15l-1.53-1.53a3.5 3.5 0 0 1 0-4.94Z"/><path d="M11.47 4.53 13 3l1.53 1.53a3.5 3.5 0 0 1 0 4.94L13 11l-1.53-1.53a3.5 3.5 0 0 1 0-4.94Z"/></svg>`,
  // Desierto — cactus
  `<svg class="eco-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22V10"/><path d="M12 13H8V9"/><path d="M12 16h4v-5"/></svg>`,
  // Bosque Boreal — pine tree (Lucide TreePine)
  `<svg class="eco-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m17 14 3 3.3a1 1 0 0 1-.7 1.7H4.7a1 1 0 0 1-.7-1.7L7 14h-.3a1 1 0 0 1-.7-1.7L9 9h-.2A1 1 0 0 1 8 7.3L12 3l4 4.3A1 1 0 0 1 15.2 9H15l3 3.3a1 1 0 0 1-.7 1.7H17z"/><path d="M9 21v-4c0-1.1.9-2 2-2h2a2 2 0 0 1 2 2v4"/></svg>`,
];
---
<section id="ecosystems" class="section-ecosystems">
  <div class="section-inner">
    <p class="section-label">Biomas</p>
    <h2 class="section-title">Los grandes reinos vegetales</h2>
    <p class="section-subtitle">
      Cada bioma es un mundo propio donde las plantas encontraron
      formas extraordinarias de prosperar contra todo pronóstico.
    </p>
    <div class="eco-grid">
      {ecosystems.map((e, i) => (
        <div class="eco-card reveal" style={`--delay:${i * 0.1}s`}>
          <div class="eco-header">
            <span class="eco-icon">
              <Fragment set:html={ecoIcons[i]} />
            </span>
            <div class="eco-stat-block">
              <span class="eco-stat">{e.stat}</span>
              <span class="eco-stat-label">{e.statLabel}</span>
            </div>
          </div>
          <div class="eco-divider" aria-hidden="true"></div>
          <h3>{e.name}</h3>
          <p>{e.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-ecosystems { background: var(--c-deep); color: var(--c-text); }

  .eco-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .eco-card {
    background: rgba(255,255,255,.04);
    border: var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--card-pad-md);
    position: relative;
    overflow: hidden;
    transition: transform var(--transition-base), border-color var(--transition-base), box-shadow var(--transition-base);
  }
  .eco-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 0% 0%, rgba(126,200,160,.09), transparent 65%);
    opacity: 0;
    transition: opacity var(--transition-base);
    pointer-events: none;
  }
  .eco-card:hover {
    transform: translateY(-6px);
    border-color: rgba(126,200,160,.35);
    box-shadow: 0 20px 40px rgba(0,0,0,.3);
  }
  .eco-card:hover::after { opacity: 1; }

  .eco-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.4rem;
  }

  .eco-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: rgba(126, 200, 160, 0.1);
    border: var(--border-subtle);
    color: var(--c-light);
    flex-shrink: 0;
  }
  .eco-svg-icon {
    width: 22px;
    height: 22px;
    display: block;
  }

  .eco-stat-block {
    text-align: right;
    flex-shrink: 0;
  }

  .eco-stat {
    display: block;
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 800;
    line-height: 1;
    background: linear-gradient(135deg, var(--c-cream), var(--c-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .eco-stat-label {
    display: block;
    font-size: var(--text-xs);
    color: var(--c-muted);
    line-height: 1.4;
    max-width: 130px;
    margin-top: .2rem;
  }

  .eco-divider {
    height: 1px;
    background: linear-gradient(to right, rgba(126,200,160,.25), transparent);
    margin-bottom: 1.2rem;
  }

  .eco-card h3 {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -.01em;
    color: var(--c-pale);
    margin-bottom: .55rem;
  }

  .eco-card p {
    font-size: var(--text-sm);
    color: var(--c-muted);
    line-height: var(--lh-loose);
  }
</style>

<script>
  import { inView, animate } from 'motion';

  document.querySelectorAll<HTMLElement>('.eco-card').forEach((card, i) => {
    inView(card, () => {
      animate(
        card,
        { opacity: [0, 1], transform: ['translateY(20px)', 'translateY(0)'] },
        { duration: 0.55, delay: i * 0.1, easing: [0.16, 1, 0.3, 1] }
      );
    }, { margin: '-10% 0px' });
  });
</script>
