  .footer-leaf {
    display: flex;
    justify-content: center;
    margin-bottom: 1.2rem;
    color: var(--c-light);
    opacity: 0.6;
  }
  .site-footer p { font-size: .9rem; line-height: 1.9; }
  .footer-note { font-size: var(--text-xs); opacity: .45; margin-top: .3rem; }
</style>
